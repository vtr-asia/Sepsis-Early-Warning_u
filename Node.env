const express = require('express');
const axios = require('axios');
const bodyParser = require('body-parser');
const app = express();

app.use(bodyParser.json());

// 這裡填入您收到的測試憑證
const CLIENT_ID = 'cc344727-6f90-496c-94fd-c7829aa9a51d';
const CLIENT_SECRET = '79f04b56b33491716c0880af72cdef7d3f0629111421cedd18353651cd313d9e';
const TOKEN_ENDPOINT = 'https://thas.mohw.gov.tw/v/r4/auth/token'; // 請依據測試手冊確認實際網址
const REDIRECT_URI = 'http://localhost:3000/callback'; 

app.get('/callback', async (req, res) => {
    const code = req.query.code; // 從前端 redirect 過來的授權碼

    if (!code) {
        return res.status(400).send('Missing authorization code');
    }

    try {
        // 使用 Basic Auth 或 POST body 傳送 secret
        const response = await axios.post(TOKEN_ENDPOINT, new URLSearchParams({
            grant_type: 'authorization_code',
            code: code,
            redirect_uri: REDIRECT_URI,
            client_id: CLIENT_ID,
            client_secret: CLIENT_SECRET // 在後端傳送，確保安全
        }), {
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
        });

        // 成功取得 Access Token
        const { access_token, patient } = response.data;
        console.log('取得 Token 成功:', access_token);
        
        // 接下來可以使用此 token 讀取該病患的 FHIR 資料 (如 Observation)
        res.json({ message: "授權成功", patientId: patient });
        
    } catch (error) {
        console.error('Token 交換失敗:', error.response?.data || error.message);
        res.status(500).send('Authentication Failed');
    }
});

app.listen(3000, () => console.log('Server running on http://localhost:3000'));